# === Wallet ===
POLYGON_RPC_URL=https://1rpc.io/matic
WALLET_ADDRESS=0xYOUR_EOA_ADDRESS
PRIVATE_KEY=your_private_key_hex_without_0x
POLYMARKET_PROXY_ADDRESS=0xYOUR_PROXY_ADDRESS

# === Polymarket API (Settings -> API Keys) ===
POLYMARKET_API_KEY=your-api-key-uuid
POLYMARKET_SECRET=your_base64_secret=
POLYMARKET_PASSPHRASE=your_passphrase_hex

# === Anthropic API ===
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
ANTHROPIC_MODEL=claude-opus-4-6

# === Telegram Notifications ===
TELE_BOT=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxx
TELE_CHAT_ID=123456789

# === API Credit Tracking ===
# Set to your actual remaining Anthropic credit in dollars
API_CREDIT_SEED=5.0
INITIAL_API_CREDIT=5.0
API_CREDIT_LEFT=5.0

# === Runtime Tuning ===
TRADE_CYCLE_SECONDS=1800
POSITION_CHECK_SECONDS=60
LOW_BALANCE_WAIT_SECONDS=1800
MAX_POSITION_RECHECKS=8
POSITION_RECHECK_MIN_EDGE=0.02
POSITION_RECHECK_STOP_EDGE=-0.02
MIN_TRADE_USDC=1.0

